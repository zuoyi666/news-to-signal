# API Keys for News Data Sources
# Copy this file to .env and fill in your actual keys
# DO NOT commit .env to GitHub!

# Finnhub API (60 calls/minute free tier)
# Get yours: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Financial Modeling Prep API (250 calls/day free tier)
# Get yours: https://financialmodelingprep.com/developer/docs/pricing
FMP_API_KEY=your_fmp_api_key_here

# Optional: Set default universe
# Options: original, sp500, russell1000
DEFAULT_UNIVERSE=russell1000
